  "markdown": "<!DOCTYPE html><html>\n\n<body id=\"authenticateUserGroup\" class=\"new-home\">\n<div class=\"page-wrapper\">\n\t<main class=\"content-wrapper\" role=\"main\">\n\t\t\n\t\t\n\t\t\t\n\t\t\n\t\t\n\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\n\n\n\n\n\n\n\n\n\n\n<section class=\"js-stage-wrapper stage-wrapper\" product-code=\"GVRL\" image-asset-url=\"https://assets.cengage.com/gale/icons/\" style=\"background-image: url(&quot;https://assets.cengage.com/gale/icons/auth-generic.jpg&quot;);\">\n\t<div class=\"gale-tag\">\n\n\t\t\n\t\t\t\n\t\t\t\n\t\t\t\t<div class=\"gale-logo\">\n\t\t\t\t\t<span class=\"offscreen\">Gale</span>\n\t\t\t\t</div>\n\t\t\t\n\t\t\n\t\t\n\t\t\t<div class=\"customer-logo\">\n\t\t\t\t<div id=\"locationBranding\"><!--DNR--></div>\n\t\t\t\t\n\t\t\t</div>\n\t\t\n\t\t\n\t\t<div class=\"stage-header\">\n\t\t\t\n\t\t\t\t<h1 class=\"resProdTitle\">Gale eBooks</h1>\n\t\t\t\t\n\t\t\t\n\t\t</div>\n\t</div>\n\n</section>\n\n\t\t<section class=\"info-wrapper\">\n\t\t\t<div class=\"info-wrapper-element\">\n\t\t\t\t<div class=\"signin-wrapper\">\n\t\t\t\t\t<div class=\"info-label\">Sign In</div>\n\t\t\t\t\t<div class=\"accent-bar\"><!--DNR--></div>\n\t\t\t\t\t<div class=\"signin-form-container\">\n\t\t\t\t\t\t<form class=\"signin-form\" role=\"form\" id=\"auth\" name=\"auth\" action=\"https://galeapps.gale.com/apps/auth\" data-gaaction=\"Login\" data-galabel=\"password\" method=\"POST\">\n\t\t\t\t\t\t\t<b>\n\t\t\t\t\t\t\t\t<span class=\"userGroup-label\">\n\t\t\t\t\t\t\t\t\tNewton South High School\n\t\t\t\t\t\t\t\t</span>\n\t\t\t\t\t\t\t</b>\n\t\t\t\t\t\t\t<div class=\"login-prompt\">Please enter your library password:</div>\n\t\t\t\t\t\t\t<div id=\"form-message&quot;\" aria-live=\"assertive\">\n\t\t\t\t\t\t\t\t<!-- Password not entered -->\n\t\t\t\t\t\t\t\t<div id=\"errorRow\" name=\"errorRow\" style=\"visibility :hidden;display:none\">\n\t\t\t\t\t\t\t\t\t<div class=\"alert alert-warning\">You did not enter any password. Please try again.</