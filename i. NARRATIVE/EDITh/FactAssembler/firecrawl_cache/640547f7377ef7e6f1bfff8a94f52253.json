  "markdown": "<!DOCTYPE html><html lang=\"en\"><!-- Rel 2009B Example Set --><!-- This File Last Changed: 29 Apr 2010 -->\n<body class=\"bodybg\">\n<!--this is customized <screens/srchhelp_X.html>-->\n<!-- begin toplogo.html file -->\n<!-- Rel 2009B Example Set -->\n<!-- Updated: 06 Oct 2010 -->\n\n\n<div class=\"minHeight\">\n<div class=\"fullPage\">\n\n<div id=\"skipNav\"><a href=\"https://stjos.sjcpl.lib.in.us/search/?searchtype=X&amp;SORT=D&amp;searcharg=xyzzyplugh9876543210abcdef#content\" tabindex=\"1\">Skip to content</a>\n</div>\n\n<div class=\"topLogo\">\n\n<div class=\"topLinks\">\n<ul id=\"topLinksList\">\n<li><a href=\"https://stjos.sjcpl.lib.in.us/patroninfo\" tabindex=\"120\">Login</a></li>\n<li><a href=\"https://stjos.sjcpl.lib.in.us/help\" tabindex=\"115\">Help</a></li>\n<li><a href=\"https://stjos.sjcpl.lib.in.us/search/?searchtype=X&amp;SORT=D&amp;searcharg=xyzzyplugh9876543210abcdef#\" tabindex=\"110\"><span class=\"buttonTopLinks\"><img src=\"https://stjos.sjcpl.lib.in.us/screens/ico_printer.gif\" alt=\"\"><span class=\"buttonTopLinksText\">Print</span></span></a></li>\n\n<li><a href=\"https://sjcpl.bibliocommons.com/\">Bibliocommons Search</a></li>\n</ul>\n</div>\n\n<!--   <div class=\"topLogoSmall\">   -->\n<!--   <a href=\"/\" tabindex=\"10\"><img src=\"/screens/clusterlogo-stack.jpg\" height=\"101\" width=\"250\" alt=\"Catalog Home Page\"></a>   -->\n<!--   </div>   -->\n\n</div>\n\n</div>\n\n<!--topLogo-->\n\n\n<div class=\"topMyLibrary\">\n<div id=\"topMyLibraryHeader\"><h1>My Library</h1></div>\n\n<ul id=\"toplogoMoreNav\">\n<!-- Toplogo alt links. -->\n\n\n<!-- Dropdown menus -->\n\t<li id=\"first\">\n\t\t<div><a href=\"https://stjos.sjcpl.lib.in.us/patroninfo\"><font-size:1.2em>My Library Account</font-size:1.2em></a></div>\n\t\t<ul>\n            <li><a href=\"https://stjos.sjcpl.lib.in.us/patroninfo\">My Account</a></li>\n            <li><a href=\"https://stjos.sjcpl.lib.in.us/patroninfo\">Renew Materials Online</a></li>\n         \n          \n           \n\t\t</ul>\n\t</li>\n\n\t<li>\n\t\t<div><a href=\"https://stjos.sjcpl.lib.in.us/help\">Help</a></div>\n\t\t<ul>\n\t\t\t\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/search\">Search the Classic Catalog</a></li>\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/screens/regconsortlinks.html\">Get a library card</a></li>\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/help#searching\">Searching</a></li>\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/help#searchtips\">Advanced Keyword Search Tips</a></li>\t\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/help#renewals\">Renewals</a></li>\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/help#feepay\">Pay Charges Online</a></li>\n\t\t\t<!--<li><a href=\"/help#rpro\">Research Pro</a></li>-->\n\t\t\t<li><a href=\"https://stjos.sjcpl.lib.in.us/help#mylist\">My Lists</a></li>\n\t\t</ul>\n\t</li>\n\n\t<!-- <li id=\"last\">\n\t\t<div><a href=\"#\">Classic Catalog</a></div>\n\t\t<ul>-->\n            \n           <!--<li><a href=\"/iii/calendar/month\">Program Calendar</a></li>\n            <li><a href=\"/ftlist\">Featured Lists</a></li>\n            <li><a href=\"/rpro\">Research Pro</a></li>\n            <li><a href=\"/search/y\">Find e-resources</a></li>\n            <li><a href=\"/illb\">Interlibrary Loan</a></li>\n\t\t</ul>\n\t</li>--> \n<!-- End dropdown menus -->    \n    \n</ul>\n\n\n\n</div><!--myLibrary-->\n<div class=\"topNavClear\"></div>\n\n<div class=\"searchNav\">\n\n<div id=\"searchNavMenu\">\n<select name=\"specializedSearch\" id=\"specializedSearch\">\n<option selected=\"selected\" value=\" \">More Searches</option>\n<option value=\"/search/X\">Advanced Keyword</option>\n<option value=\"/search/t\">Title</option>\n<option value=\"/search/a\">Author</option>\n<option value=\"/search/q\">Author and Title</option>\n<option value=\"/search/b\">Bar Code</option>\n<option value=\"/search/i\">ISBN</option>\n<option value=\"/search/o\">OCLC</option>\n<option value=\"/search/d\">Subject</option>\n<option value=\"/search/c\">Call Number</option>\n\n<!--<option value=\"/search/p\">Instructor</option>\n<option value=\"/search/r\">Course</option> -->\n</select>\n<input type=\"image\" src=\"https://stjos.sjcpl.lib.in.us/screens/ico_go.gif\" class=\"searchNavBut\" value=\"Go\">\n</div>\n\n</div><!--searchNav-->\n<div class=\"clear\"></div>\n<div class=\"pageContent\"><!-- content container -->\n<a name=\"content\" id=\"content\"></a>\n<!--end toplogo.html-->\n\t\t\t\t\t\t\n\n<div class=\"pageContentInner\">\n<h1 class=\"pageHeader\">Advanced Keyword Search</h1>\n<br><h2>NO ENTRIES FOUND</h2><br>\n\n<div class=\"form3Part\" id=\"accessibleForm\">\n\n\n<!-- FOR USE IN ADVANCED SEARCH PAGES (e.g.: srchhelp_X.html) ONLY -->\n<!-- FOR PHRASE SEARCH PAGES USE TOKEN: formbegin -->\n<form action=\"https://stjos.sjcpl.lib.in.us/search/?searchtype=X&amp;SORT=D&amp;searcharg=xyzzyplugh9876543210abcdef#\" enctype=\"multipart/form-data: charset=UTF-8\" name=\"search\" id=\"search\">\n<div class=\"form3PartAbove\">\n<fieldset>\n<legend>Enter Search Terms</legend>\n<div class=\"formEntryArea\">\n<label for=\"fl1\" class=\"advSearchFieldLabel\">Field 1</label>\n<select id=\"fl1\" name=\"fieldLimit1\" title=\"field limit 1\">\n<option value=\"\" selected=\"selected\">Any Field:</option>\n<option value=\"a:\">AUTHOR:</option>\n<option value=\"t:\">TITLE:</option>\n<option value=\"d:\">SUBJECT:</option>\n<option value=\"N:\">Note:</option>\n</select>\n\n<label for=\"st1\" class=\"advSearchTextLabel\">Search Text 1</label>\n<input maxlength=\"75\" size=\"35\" name=\"searchText1\" id=\"st1\" title=\"search text 1\">\n<label for=\"bl1\" class=\"advSearchBooleanLabel\">Boolean 1</label>\n<select name=\"boolean1\" id=\"bl1\" title=\"Boolean 1\">\n<option value=\"%20and%20\" selected=\"selected\">And</option>\n<option value=\"%20and%20not%20\">And not</option>\n<option value=\"%20or%20\">Or</option>\n</select>\n\n<br>\n\n<label for=\"fl2\" class=\"advSearchFieldLabel\">Field 2</label>\n<select id=\"fl2\" name=\"fieldLimit2\" title=\"field limit 2\">\n<option value=\"\" selected=\"selected\">Any Field:</option>\n<option value=\"a:\">AUTHOR:</option>\n<option value=\"t:\">TITLE:</option>\n<option value=\"d:\">SUBJECT:</option>\n<option value=\"N:\">Note:</option>\n</select>\n\n<label for=\"st2\" class=\"advSearchTextLabel\">Search Text 2</label>\n<input maxlength=\"75\" size=\"35\" name=\"searchText2\" id=\"st2\" title=\"search text 2\">\n<label for=\"bl2\" class=\"advSearchBooleanLabel\">Boolean 2</label>\n<select name=\"boolean2\" id=\"bl2\" title=\"Boolean 2\">\n<option value=\"%20and%20\" selected=\"selected\">And</option>\n<option value=\"%20and%20not%20\">And not</option>\n<option value=\"%20or%20\">Or</option>\n</select>\n\n<br>\n\n<label for=\"fl3\" class=\"advSearchFieldLabel\">Field 3</label>\n<select id=\"fl3\" name=\"fieldLimit3\" title=\"field limit 3\">\n<option value=\"\" selected=\"selected\">Any Field:</option>\n<option value=\"a:\">AUTHOR:</option>\n<option value=\"t:\">TITLE:</option>\n<option value=\"d:\">SUBJECT:</option>\n<option value=\"N:\">Note:</option>\n</select>\n\n<label for=\"st3\" class=\"advSearchTextLabel\">Search Text 3</label>\n<input maxlength=\"75\" size=\"35\" name=\"searchText3\" id=\"st3\" title=\"search text 3\">\n<label for=\"bl3\" class=\"advSearchBooleanLabel\">Boolean 3</label>\n<select name=\"boolean3\" id=\"bl3\" title=\"Boolean 3\">\n<option value=\"%20and%20\" selected=\"selected\">And</option>\n<option value=\"%20and%20not%20\">And not</option>\n<option value=\"%20or%20\">Or</option>\n</select>\n\n<br>\n\n<label for=\"fl4\" class=\"advSearchFieldLabel\">Field 4</label>\n<select id=\"fl4\" name=\"fieldLimit4\" title=\"field limit 4\">\n<option value=\"\" selected=\"selected\">Any Field:</option>\n<option value=\"a:\">AUTHOR:</option>\n<option value=\"t:\">TITLE:</option>\n<option value=\"d:\">SUBJECT:</option>\n<option value=\"N:\">Note:</option>\n</select>\n\n<label for=\"st4\" class=\"advSearchTextLabel\">Search Text 4</label>\n<input maxlength=\"75\" size=\"35\" name=\"searchText4\" id=\"st4\" title=\"search text 4\">\n</div>\n\n<div class=\"formEntryArea\">\n<input type=\"checkbox\" name=\"availlim\" id=\"availlim\" value=\"1\">\n<span class=\"availLimMessage\">To limit your search to available items, check the box and click on Search.</span></div>\n<div class=\"formButtonArea\">\n<span>\n\n<a href=\"https://stjos.sjcpl.lib.in.us/search/?searchtype=X&amp;SORT=D&amp;searcharg=xyzzyplugh9876543210abcdef#\"><div><div class=\"buttonSpriteDiv\"><span class=\"buttonSpriteSpan1\"><span class=\"buttonSpriteSpan2\">Submit</span></span></div></div></a>\n</span>\n<span>\n<a href=\"https://stjos.sjcpl.lib.in.us/search/?searchtype=X&amp;SORT=D&amp;searcharg=xyzzyplugh9876543210abcdef#\"><div><div class=\"buttonSpriteDiv\"><span class=\"buttonSpriteSpan1\"><span class=\"buttonSpriteSpan2\">Clear Form</span></span></div></div></a>\n</span>\n</div>\n</fieldset>\n</div> <!-- form3PartAbove -->\n\n<div class=\"form3PartBelow\">\n\n<div class=\"formLeft advancedSearch\">\n<fieldset>\n<legend>Add Limits (Optional)</legend>\n\n<!-- Optional Scopes section\n<div class=\"formEntryArea\">\n<table><tr>\n<td><label for=\"searchscope\">Location:</label></td>\n<td> -->\n <!--{scope}-->\n<!--</td></tr></table>\n</div> -->\n\n<div class=\"formEntryArea\">\n<table border=\"0\">\n<tbody><tr><td><label for=\"b\">Location:</label></td>\n<td><select id=\"b\" name=\"b\" size=\"5\" multiple=\"multiple\">\n<option value=\"\">ANY</option>\n<option value=\"ctr\">Centre Twp Branch</option>\n<option value=\"ger\">German Twp Branch</option>\n<option value=\"las\">LaSalle Branch</option>\n<option value=\"lkv\">Lakeville Branch</option>\n<option value=\"mai\">Main Library</option>\n<option value=\"nlb\">N. Liberty Branch</option>\n<option value=\"rbf\">Francis Branch</option>\n<option value=\"rvp\">River Park Branch</option>\n<option value=\"vmt\">Tutt Branch</option>\n<option value=\"wes\">Western Branch</option>\n</select>\n</td>\n</tr></tbody></table>\n\n</div>\n<div class=\"formEntryArea\">\n<table border=\"0\">\n<tbody><tr><td><label for=\"m\">Format:</label></td>\n<td><select id=\"m\" name=\"m\" size=\"5\" multiple=\"multiple\">\n<option value=\"\">ANY</option>\n<option value=\"b\">Book</option>\n<option value=\"d\">DVD</option>\n<option value=\"u\">BLU-RAY</option>\n<option value=\"a\">Audiobook CD</option>\n<option value=\"c\">Music CD</option>\n<option value=\"p\">Magazine</option>\n<option value=\"g\">Video Game</option>\n<option value=\"j\">Launchpad</option>\n<option value=\"f\">Microform</option>\n<option value=\"e\">Equipment</option>\n<option value=\"z\">Pass</option>\n</select>\n</td>\n</tr></tbody></table>\n\n</div>\n<div class=\"formEntryArea\">\n<table border=\"0\">\n<tbody><tr><td><label for=\"l\">Language:</label></td>\n<td><select id=\"l\" name=\"l\" size=\"5\" multiple=\"multiple\">\n<option value=\"\">ANY</option>\n<option value=\"eng\">English</option>\n<option value=\"fre\">French</option>\n<option value=\"ger\">German</option>\n<option value=\"ita\">Italian</option>\n<option value=\"spa\">Spanish</option>\n<option value=\"rus\">Russian</option>\n<option value=\"pol\">Polish</option>\n<option value=\"jpn\">Japanese</option>\n<option value=\"hun\">Hungarian</option>\n</select>\n</td>\n</tr></tbody></table>\n\n</div>\n<div class=\"formEntryArea\">\n<table border=\"0\">\n\n\n<tbody><tr><td><fieldset>\n <legend>Within</legend>\n<label for=\"Da\"> From </label>\n<input type=\"text\" size=\"10\" name=\"Da\" id=\"Da\" value=\"\"> <label for=\"Db\">to</label>\n<input type=\"text\" size=\"10\" name=\"Db\" id=\"Db\" value=\"\">\n</fieldset></td></tr></tbody></table>\n\n</div>\n<div class=\"formEntryArea\">\n<table border=\"0\">\n<tbody><tr><td><label for=\"p\">Publisher:</label></td>\n<td><input type=\"text\" size=\"20\" name=\"p\" id=\"p\" value=\"\">\n</td>\n</tr></tbody></table>\n\n</div>\n<div class=\"formEntryArea\" id=\"form3PartAdvLimitSort\">\n<label for=\"SORT\"> Search and Sort:</label><select name=\"SORT\" id=\"SORT\">\n<option value=\"D\" selected=\"selected\">sorted by relevance</option><option value=\"DX\">sorted by date</option><option value=\"AX\">sorted by title</option></select>\n</div>\n</fieldset>\n\n</div> <!-- formLeft -->\n\n<div class=\"formRight\">\n<table class=\"tipsTable\">\n<caption>Search Tips</caption>\n<!-- <tr valign=\"top\"><th align=\"left\">Adjacency</th>\n<td>Multiple words are searched together as one phrase.<br>\n<span style=\"text-decoration:underline\">Example</span> : world health organization</td>\n</tr> -->\n<tbody><tr><th>Wildcards</th>\n<td>\nWords may be right-hand truncated using an asterisk ('*') in place of other characters. <!-- Use '**' for open-ended truncation of over five characters.--> The '*' wildcard may also be embedded in a search string. You may use '?' to replace a single character anywhere within a word.<br>\n<span style=\"text-decoration:underline\">Examples</span> : environment* polic*, wom?n</td>\n</tr>\n<tr><th>Boolean Operators</th>\n<td>\nUse \"and\" or \"or\" to specify multiple words in any field, any order. Use \"and not\" to exclude words.<br>\n<span style=\"text-decoration:underline\">Example</span> : stocks and bonds<br>\n<span style=\"text-decoration:underline\">Example</span> : (alaska or canada) and (adventure and not vacation)</td>\n</tr>\n<tr><th>Field limits</th>\n<td>\nA field limit causes the system to search only the specified field for the specified word(s).</td>\n</tr>\n<tr>\n<th>Grouping</th>\n<td>\nKeyword search results are usually grouped by relevance to bring the most likely titles to the top of the list. Each group represents a similar level of relevance and results are sorted within the group by date or title. To get an ungrouped result set, use boolean operators to form a complex query.\n</td>\n</tr>\n<!-- <tr valign=\"top\"><th align=\"left\">Proximity Operators</th>\n<td>\nUse \"near\" to specify words close to each other, in any order.<br>\n<span style=\"text-decoration:underline\">Example</span> : california near university</td>\n</tr> -->\n</tbody></table>\n</div> <!-- formRight -->\n<div class=\"clear\"></div>\n</div> <!-- form3PartBelow -->\n\n</form>\n</div> <!-- form3Part -->\n\n</div><!-- pageContentInner -->\n\n<!-- begin botlogo.html file -->\n<!-- Rel 2009B Example Set -->\n<!-- Updated: Sept 2009 -->\n</div><!-- pageContent  -->\n<div style=\"clear:both\"></div>\n</div><!-- fullPage -->\n<!-- min-height -->\n<!-- end botlogo.html file -->\n\n\n\n\n\n\n\n</body></html>",
