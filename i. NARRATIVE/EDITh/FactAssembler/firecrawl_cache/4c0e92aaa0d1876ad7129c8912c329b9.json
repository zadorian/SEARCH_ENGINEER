on class=\"fl-input-clear fl-no-padding fl-hidden\" type=\"button\" aria-label=\"Clear search\" aria-hidden=\"true\">\n                                                        <i class=\"fa fa-times-circle small\" aria-hidden=\"true\"></i>\n                                                    </button>\n                                                </div>\n                                            </div>\n                                            <ul id=\"fl-lawyer-search-form-legal-issue-input-dropdown\" class=\"fl-legal-issue-input-dropdown fl-dropdown-input-dropdown\" role=\"listbox\" data-testid=\"fl-lawyer-search-form-legal-issue-input-dropdown\">\n                                                <li class=\"fl-list-item fl-legal-issue-input-dropdown-list-item fl-more-options-separator\" role=\"option\" aria-selected=\"false\" data-testid=\"More Options\">\n                                                    <span>More Options</span>\n                                                </li>\n                                                <li class=\"fl-list-item fl-legal-issue-input-dropdown-list-item fl-more-options-list-item fl-list-item-link\" role=\"option\" aria-selected=\"false\" data-testid=\"Name Search\">\n                                                    <a class=\"fl-legal-issue-input-dropdown-list-item-link fl-list-item-link\" href=\"https://lawyers.findlaw.com/name-search/\" aria-label=\"More options: Name Search\" tabindex=\"-1\" target=\"_blank\" rel=\"noopener\">\n                                                        Name Search\n                                                    </a>\n                                                </li>\n                                                <li class=\"fl-list-item fl-legal-issue-input-dropdown-list-item fl-more-options-list-item fl-list-item-link\" role=\"option\" aria-selected=\"false\" data-testid=\"Browse Legal Issues\">\n                                                    <a class=\"fl-legal-issue-input-dropdown-list-item-link fl-list-item-link\" href=\"https://lawyers.findlaw.com/legal-issues/\" aria-label=\"More options: Browse Legal Issues\" tabindex=\"-1\" target=\"_blank\" rel=\"noopener\">\n                                                        Browse Legal Issues\n                                                    </a>\n                                                </li>\n                                                <li class=\"fl-list-item fl-legal-issue-input-dropdown-list-item fl-more-options-list-item fl-list-item-link\" role=\"option\" aria-selected=\"false\" data-testid=\"Browse Law Firms\">\n                                                    <a class=\"fl-legal-issue-input-dropdown-list-item-link fl-list-item-link\" href=\"https://lawyers.findlaw.com/profile/lawfirm/a/1.html\" aria-label=\"More options: Browse Law Firms\" tabindex=\"-1\" target=\"_blank\" rel=\"noopener\">\n                                                        Browse Law Firms\n                                                    </a>\n                                                </li>\n                                                <li class=\"fl-list-item fl-legal-issue-input-dropdown-list-item fl-more-options-list-item fl-list-item-link\" role=\"option\" aria-selected=\"false\" data-testid=\"Support\">\n                                                    <a class=\"fl-legal-issue-input-dropdown-list-item-link fl-list-item-link\" href=\"https://lawyers.findlaw.com/lawyer/help/\" aria-label=\"More options: Support\" tabindex=\"-1\" target=\"_blank\" rel=\"noopener\">\n                                                        Support\n                                                    </a>\n                                                </li>\n                                            </ul>\n                                        </div>\n                                        <div class=\"fl-dropdown-input fl-location-input\" data-testid=\"fl-dropdown-input\">\n                                            <label for=\"fl-lawyer-search-form-location-input\" class=\"fl-form-input-label fl-dropdown-input-label fl-search-bar-form-input-label\" data-testid=\"fl-lawyer-search-form-location-input-label\">\n                                                I need help near\n                                                <span class=\"fl-text\">\n                                                    &nbsp;(City, ZIP Code or County)\n                                                </span>\n                                            </label>\n                                            <div class=\"fl-input fl-flex fl-flex-column\">\n                                                <div class=\"fl-input-wrapper\">\n                                                    <input class=\"fl-input-field pac-target-input\" data-testid=\"fl-input-field\" aria-required=\"false\" aria-invalid=\"false\" id=\"fl-lawyer-search-form-location-input\" type=\"text\" maxlength=\"255\" role=\"combobox\" autocomplete=\"off\" aria-autocomplete=\"both\" aria-haspopup=\"listbox\" aria-expanded=\"false\" aria-controls=\"fl-lawyer-search-form-location-input-dropdown\" placeholder=\" \" name=\"location\" value=\"\">\n                                                    <button class=\"fl-input-clear fl-no-padding\" type=\"button\" aria-label=\"Clear search\" aria-hidden=\"false\">\n                                                        <i class=\"fa fa-times-circle small\" aria-hidden=\"true\"></i>\n                                                    </button>\n                                                </div>\n                                            </div>\n                                            <ul id=\"fl-lawyer-search-form-location-input-dropdown\" class=\"fl-location-input-dropdown fl-dropdown-input-dropdown\" role=\"listbox\" data-testid=\"fl-dropdown-input-dropdown\"></ul>\n                                        </div>\n                                    </div>\n                                    \n                                    <div id=\"lawyer-search-form-error\" tabindex=\"-1\" class=\"fl-field-error fl-items-center fl-flex fl-inline-search-form-error fl-hidden\" aria-hidden=\"false\" data-testid=\"error-block\" role=\"alert\">\n                                        <i class=\"fa fa-exclamation-circle medium\" aria-hidden=\"true\"></i>\n                                        <span class=\"fl-field-error-message\">\n                                            Enter either your legal issue or location to continue\n                                        </span>\n                                    </div>\n                                    <button class=\"fl-button primary fl-inline-search-form-submit\" type=\"submit\" aria-disabled=\"false\" data-testid=\"fl-inline-search-form-submit\">\n                                        <span class=\"fl-button-content\">Find a Lawyer</span>\n                                        <i class=\"fa fa-angle-right medium\" aria-hidden=\"true\"></i>\n                                    </button>\n                                </form>\n                            </div>\n                            <div class=\"fl-more-options fl-flex fl-flex-column fl-more-options-standalone fl-lawyer-search-form-more-options fl-lawyer-search-form-mobile\" data-testid=\"fl-more-options\">\n                                <div class=\"fl-more-options-separator\" data-testid=\"fl-more-options-separator\">\n                                    More Options\n                                </div>\n                                <div class=\"fl-more-options-links\" data-testid=\"fl-more-options-links\">\n                                    <ul class=\"fl-list fl-more-options-list\" data-testid=\"fl-more-options-tabs-links\">\n                                        <li data-testid=\"fl-more-options-list-item-0\" class=\"fl-list-item fl-more-options-list-item\">\n                                            <a href=\"https://lawyers.findlaw.com/name-search/\" class=\"fl-list-item-link\" data-testid=\"fl-more-options-link-0\" target=\"_blank\" rel=\"noopener\">\n                                                Name Search\n                                            </a>\n                                        </li>\n                                        <li data-testid=\"fl-more-options-list-item-1\" class=\"fl-list-item fl-more-options-list-item\">\n                                            <a href=\"https://lawyers.findlaw.com/legal-issues/\" class=\"fl-list-item-link\" data-testid=\"fl-more-options-link-1\" target=\"_blank\" rel=\"noopener\">\n                                                Browse Legal Issues\n                                            </a>\n                                        </li>\n                                        <li data-testid=\"fl-more-options-list-item-2\" class=\"fl-list-item fl-more-options-list-item\">\n                                            <a href=\"https://lawyers.findlaw.com/profile/lawfirm/a/1.html\" class=\"fl-list-item-link\" data-testid=\"fl-more-options-link-2\" target=\"_blank\" rel=\"noopener\">\n                                                Browse Law Firms\n                                            </a>\n                                        </li>\n                                        <li data-testid=\"fl-more-options-list-item-3\" class=\"fl-list-item fl-more-options-list-item\">\n                                            <a href=\"https://lawyers.findlaw.com/lawyer/help/\" class=\"fl-list-item-link\" data-testid=\"fl-more-options-link-3\" target=\"_blank\" rel=\"noopener\">\n                                                Support\n                                            </a>\n                                        </li>\n                                    </ul>\n                                </div>\n                            </div>\n                        </div>\n                        <button type=\"button\" aria-label=\"Close modal\" class=\"fl-modal-close-button\" data-testid=\"fl-modal-close\">\n                            <i class=\"fa fa-close small\" aria-hidden=\"true\"></i>\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n</div>\n<section class=\"section-container\">\n    <h2 class=\"section-container__title fl-h2-landing\">Find the Right Starting Point</h2>\n    <div class=\"section-container__header-note fl-text-lg\"><p>Not sure which area of law fits your situation? You can browse by common legal issues, state laws, or legal categories. You can also see an alphabetical list of FindLaw’s legal issues. Use the tabs below to start with the best option for your needs.</p>\n</div>\n    <div class=\"section-container__body\">\n        <div class=\"latl-module\"><section class=\"latl-content\" data-testid=\"latl-content\"><div class=\"fl-content-tabs content-tabs-no-margin\"><div class=\"fl-tabs-desktop\"><div class=\"fl-tabs-wrapper fl-flex\" role=\"tablist\"><button type=\"button\" data-testid=\"fl-tab-button-1\" class=\"fl-tab-button fl-tab-button-text fl-text-lg-bold fl-active-tab\" role=\"tab\" tabindex=\"0\" aria-selected=\"true\">Common Legal Issues</button><button type=\"button\" data-testid=\"fl-tab-button-2\" class=\"fl-tab-button fl-tab-button-text fl-text-lg-bold \" role=\"tab\" tabindex=\"-1\" aria-selected=\"false\">State Laws</button><button type=\"button\" data-testid=\"fl-tab-button-3\" class=\"fl-tab-button fl-tab-button-text fl-text-lg-bold \" role=\"tab\" tabindex=\"-1\" aria-selected=\"false\">Legal Categories</button><button type=\"button\" data-testid=\"fl-tab-button-4\" class=\"fl-tab-button fl-tab-button-text fl-text-lg-bold \" role=\"tab\" tabindex=\"-1\" aria-selected=\"false\">Legal Issues A - Z</button></div><div class=\"fl-tabs-content\"><div class=\"fl-container fl-section-title fl-text-center\" data-testid=\"fl-section-title\"><h3 class=\"fl-section-title-heading fl-no-margin fl-h3-landing\" data-testid=\"fl-section-title-heading\">Common Legal Issues</h3><p class=\"fl-section-title-content fl-no-margin\" data-testid=\"fl-section-title-content\">Use the lists of common legal areas below to find a starting point. These legal topics are often called \"practice areas.\" Each box lists the most common concerns and issues within the practice area.</p></div><div class=\"fl-cards fl-flex fl-flex-wrap fl-justify-center fl-align-strech\"><div class=\"fl-image-card fl-image-card--no-max-width fl-image-card--no-min-height fl-card\"><div class=\"fl-image-card-image-wrapper fl-desktop fl-image-card-image-wrapper-large\"><img loading=\"lazy\" alt=\"\" src=\"https://www.findlaw.com/static/c/images/images/w_1200,c_limit,dpr_auto/f_auto,q_auto:eco/v1750684225/ability-law/wp-prod/www-tabs-img-small-1/www-tabs-img-small-1.jpg?_i=AA\"></div><div class=\"fl-image-card-content\"><h3 class=\"fl-title-H3 fl-image-card-title fl-image-card-title-default\">Criminal Law</h3><section class=\"fl-list-control\" data-testid=\"fl-list-control\"><ul class=\"fl-list-control-list fl-text-bold\" data-testid=\"fl-list-control-list\"><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/criminal/criminal-charges.html\"><span>Criminal Charges</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/criminal/criminal-rights.html\"><span>Your Rights When Accused</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/criminal/expungement.html\"><span>Expungement of a Crime</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/criminal.html\"><span>View Criminal Law Topics</span></a></div></li></ul></section></div></div><div class=\"fl-image-card fl-image-card--no-max-width fl-image-card--no-min-height fl-card\"><div class=\"fl-image-card-image-wrapper fl-desktop fl-image-card-image-wrapper-large\"><img loading=\"lazy\" alt=\"\" src=\"https://www.findlaw.com/static/c/images/images/w_1200,c_limit,dpr_auto/f_auto,q_auto:eco/v1750684355/ability-law/wp-prod/www-tabs-img-small-2/www-tabs-img-small-2.jpg?_i=AA\"></div><div class=\"fl-image-card-content\"><h3 class=\"fl-title-H3 fl-image-card-title fl-image-card-title-default\">Family Law</h3><section class=\"fl-list-control\" data-testid=\"fl-list-control\"><ul class=\"fl-list-control-list fl-text-bold\" data-testid=\"fl-list-control-list\"><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/family/child-custody.html\"><span>Child Custody</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/family/child-support.html\"><span>Child Support</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/family/divorce.html\"><span>Divorce</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/family.html\"><span>View Family Law Topics</span></a></div></li></ul></section></div></div><div class=\"fl-image-card fl-image-card--no-max-width fl-image-card--no-min-height fl-card\"><div class=\"fl-image-card-image-wrapper fl-desktop fl-image-card-image-wrapper-large\"><img loading=\"lazy\" alt=\"\" src=\"https://www.findlaw.com/static/c/images/images/w_1200,c_limit,dpr_auto/f_auto,q_auto:eco/v1750684519/ability-law/wp-prod/www-tabs-img-small-3/www-tabs-img-small-3.jpg?_i=AA\"></div><div class=\"fl-image-card-content\"><h3 class=\"fl-title-H3 fl-image-card-title fl-image-card-title-default\">Real Estate Law</h3><section class=\"fl-list-control\" data-testid=\"fl-list-control\"><ul class=\"fl-list-control-list fl-text-bold\" data-testid=\"fl-list-control-list\"><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/realestate/landlord-tenant-law.html\"><span>Landlord-Tenant Law</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/realestate/buying-a-home.html\"><span>Buying a Home</span></a></div></li><li class=\"fl-list-control-list-item fl-flex\"><div class=\"fl-list-control-container\"><i class=\"fa fa-angle-right small \" aria-hidden=\"true\"></i></div><div class=\"fl-list-control-text\"><a href=\"https://www.findlaw.com/realestate/foreclosure.html\"><span>Foreclosure</span></a></div></li><li class=\"fl-list-control-list-item fl