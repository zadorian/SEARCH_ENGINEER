  "markdown": "<!DOCTYPE html><html lang=\"pt-BR\">\n\n<body>\n<!-- Google Tag Manager (noscript) -->\n\n<!-- End Google Tag Manager (noscript) -->\n<!-- INÍCIO DA BARRA DO GOVERNO -->\n<!-- <iframe src=\"/includes/barragov.php\" frameborder=\"0\" style=\"width: 100%; height: 44px; margin: 0; padding: 0;\"></iframe> -->\n<div class=\"barra-do-governo\" style=\"position: relative;z-index: 10000000;\">\n\t    \n    \n    <div class=\"barra-body\">\n\n        <div id=\"barra-brasil\"><div class=\"conteudo-escondido\"> <a accesskey=\"1\" href=\"https://www.ibge.gov.br/#conteudo\">Ir para o conteúdo</a> </div> <div class=\"conteudo-barra-brasil\"> <a href=\"https://gov.br/\" class=\"pic-gov\" title=\"GovBR\">GovBR</a>  </div></div>\n        <!-- Barra Brasil-->\n        \n            \n    </div>\n \n</div>\n<!-- FIM DA BARRA DO GOVERNO -->\n\n \n\n<!-- Inicio conteudo -->\n    <main class=\"conteudo pure-g\">      \n\n        <!-- Exibicao erro servico -->\n        <div id=\"container-erro-servico\" class=\"erro-servico\">\n            <div class=\"largura-maxima\">\n                <p class=\"erro-servico-label\">Nossos serviços estão apresentando instabilidade no momento. Algumas informações podem não estar disponíveis.</p>\n                <div id=\"descricao-erro\"></div>\n            </div>\n        </div>\n    \n\n\n                        <section class=\" pure-u-1 \">\n                    <!--<h2>Resultados</h2>-->\n\t\t\t\t\t\t\t<div class=\"largura-maxima\">\n\t\t\t\t\t<p class=\"busca__sem-resultados\"><b>Não há resultados para a sua busca.</b><br><small>Tente buscas como IPCA, PIB, Desemprego ou Censo.</small></p>\n\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\n\t\t\t\t\t\n\t\t\n\t\t\n\t\n\n\n\n                </section>\n            \n                    \n    </main>\n<!-- Fim conteudo -->\n\n<!----- INÍCIO DO RODAPÉ --- -->   \n\n\n\n\n\n\n\n\n<!----- FIM DO RODAPÉ --- --><img src=\"https://cod.ibge.gov.br/qr?d=https://www.ibge.gov.br/busca.html?searchword=xyzzyplugh9876543210abcdef&amp;searchphrase=all\" class=\"qrcodeimg\">\n\n\n<!-- Menu -->\n\n\n<!--<script  src=\"/media/util/questionario.js\" type=\"text/javascript\"></script>-->\n\n<!-- Tratamento de erros do serviço -->\n\n\n\n\n<!-- Google analytics -->\n\n\n\n<link rel=\"stylesheet\" href=\"https://www.ibge.gov.br/includes/CEON.cookiebar/cookiebar.css?v=2023\">\n<div class=\"cookie-container\" id=\"cookie-container\">\n    <p>Nós utilizamos cookies para melhorar sua experiência de navegação no portal. Para saber mais sobre como tratamos os dados pessoais, consulte nossa <a href=\"https://www.ibge.gov.br/acesso-informacao/acoes-e-programas/politica-de-privacidade.html\" target=\"_blank\" rel=\"noopener\">Política de Privacidade.</a></p>\n    <button class=\"cookie-btn\" id=\"cookie-btn\"> PROSSEGUIR </button>\n</div>\n\n\n<div><div vw=\"\" class=\"enabled\" style=\"left: initial; right: 0px; top: 50%; bottom: initial; transform: translateY(calc(-50% - 10px));\"><div vw-access-button=\"\" class=\"active\" style=\"width: 200px;\"><img class=\"vp-access-button\" data-src=\"assets/access_icon.svg\" alt=\"Conteúdo acessível em Libras usando o VLibras Widget com opções dos Avatares Ícaro, Hosana ou Guga.\" src=\"https://vlibras.gov.br/app2//assets/access_icon.svg\">\n<img class=\"vp-pop-up\" data-src=\"assets/access_popup.jpg\" alt=\"Conteúdo acessível em Libras usando o VLibras Widget com opções dos Avatares Ícaro, Hosana ou Guga.\" src=\"https://vlibras.gov.br/app2//assets/access_popup.jpg\">\n</div><div vw-plugin-wrapper=\"\"><div vp=\"\">\n  <div vp-box=\"\"></div>\n  <div vp-message-box=\"\"></div>\n  <div vp-settings=\"\"></div>\n  <div vp-dictionary=\"\"></div>\n  <div vp-settings-btn=\"\"></div>\n  <div vp-info-screen=\"\"></div>\n  <div vp-suggestion-screen=\"\"></div>\n  <div vp-translator-screen=\"\"></div>\n  <div vp-more-options-screen=\"\"></div>\n  <div vp-emotions-tooltip=\"\"></div>\n  <div vp-main-guide-screen=\"\"></div>\n  <div vp-suggestion-button=\"\"></d